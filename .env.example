# BundleScan environment — copy to .env and fill in.
# NEVER commit the real .env (handoff §4). On the VPS keep a secrets file outside the repo.

# ── Realtime source (FREE — no key needed) ───────────────────────────────────
# New pump.fun launches stream from PumpPortal's free WebSocket. Each new mint
# triggers a cheap slot-level RPC replay (hybrid) that catches the atomic bundle.
PUMPPORTAL_WS_URL=wss://pumpportal.fun/api/data
# Hybrid indexer throttle (protects the free RPC; raise on a faster RPC).
LIVE_SCAN_CONCURRENCY=2      # launches replayed in parallel
LIVE_SCAN_DELAY_MS=4000      # wait before replay so blocks settle on-chain
LIVE_QUEUE_MAX=40            # backlog cap → excess launches are sampled/dropped
MIN_SOL_RAISED=0             # spam guard: skip launches that raised < N SOL at create

# ── RPC (FREE, no key) — used by the hybrid indexer AND on-demand scans ──────
# Default is a free, no-key public RPC. To survive rate limits, set RPC_URLS to a
# comma-separated list of free RPCs — they're rotated round-robin to spread load.
RPC_URL=https://solana-rpc.publicnode.com
RPC_URLS=https://solana-rpc.publicnode.com,https://rpc.ankr.com/solana,https://api.mainnet-beta.solana.com

# ── Helius — NOT USED / NOT REQUIRED. Leave blank to stay 100% free. ─────────
# (Only if you ever want to: setting a key would route RPC through Helius.)
HELIUS_API_KEY=
HELIUS_RPC_URL=
HELIUS_WEBHOOK_SECRET=

# ── Datastores ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://bundlescan:bundlescan@localhost:5432/bundlescan?schema=public
REDIS_URL=redis://localhost:6379

# ── Payments (on-chain SOL → tier) ───────────────────────────────────────────
# Treasury wallet that receives subscription SOL. Public key only.
TREASURY_PUBKEY=
# Tier pricing in SOL (placeholders — ALFA to finalize, handoff §11/§13).
PRICE_OPERATOR_SOL=2
PRICE_SYNDICATE_SOL=8
# Client-visible copies used by the in-browser wallet flow (must be NEXT_PUBLIC_).
NEXT_PUBLIC_TREASURY_PUBKEY=
NEXT_PUBLIC_PRICE_OPERATOR_SOL=2
NEXT_PUBLIC_PRICE_SYNDICATE_SOL=8
NEXT_PUBLIC_RPC_URL=

# ── Auth / sessions ──────────────────────────────────────────────────────────
# HMAC secret for signed session cookies — set a long random value in prod.
SESSION_SECRET=

# ── Worker ───────────────────────────────────────────────────────────────────
WORKER_MODE=all
ALERT_INTERVAL_MS=60000
# Set to run the Telegram bot in webhook mode instead of long-polling.
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# ── Telegram bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# Public base URL used in deep links / share-card URLs.
PUBLIC_BASE_URL=https://bundlescan.io

# ── Verdict copy (optional — deterministic-friendly templating only) ─────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# ── Fourtis ecosystem cross-link ─────────────────────────────────────────────
DEVRADAR_API_URL=
